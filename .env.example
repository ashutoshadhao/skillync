# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Supabase Postgres)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Gemini AI
GEMINI_API_KEY=

# Adzuna job-search API (primary job source) — free dev tier at https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron Security
CRON_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# Local development with docker-compose (Postgres + Mailpit)
#   docker compose up -d   →   then set these in .env.local:
#
# Then run the app on your host with `npm run dev`:
#   DATABASE_URL=postgresql://skillync:skillync@localhost:5432/skillync
#   (run `npm run db:push` once to create the tables)
#
# Mailpit SMTP (enter in Settings → Email; no auth needed). Inbox: http://localhost:8025
#   SMTP host: localhost   SMTP port: 1025
# ──────────────────────────────────────────────────────────────────────────────
